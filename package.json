{
  "name": "tft-traits-web-exploration-tool",
  "version": "0.0.1",
  "description": "TFT Traits Web Exploration Tool - Desktop app for exploring optimal TFT board compositions",
  "main": "build/main.js",
  "license": "Apache-2.0",
  "scripts": {
    "start": "npm run build && electron .",
    "dev:renderer": "vite",
    "dev:electron": "npm run build:node && node build/tools/run-electron-dev.js",
    "build": "npm run build:node && npm run build:renderer",
    "build:node": "tsc && node -e \"const fs=require('node:fs'); fs.cpSync('assets','build/assets',{recursive:true}); fs.copyFileSync('favicon.svg','build/favicon.svg');\"",
    "build:renderer": "vite build",
    "help": "npm run",
    "test": "npm run build:node && node build/tools/run-node-tests.js",
    "test:smoke": "npm run build && node build/tools/run-electron-smoke.js",
    "test:smoke:unit": "npm run build:node && node --test build/test/window-service.test.js",
    "test:all": "npm test && npm run test:smoke && npm run lint",
    "lint": "eslint \"**/*.ts\" \"**/*.tsx\"",
    "typecheck": "tsc --noEmit",
    "validate:data": "npm run build:node && node build/tools/validate-data-sources.js",
    "pack:win": "npm run build && electron-packager . \"TFT Board Exploration Tool\" --platform=win32 --arch=x64 --icon=assets/app-icon.ico --out=dist --overwrite --asar --ignore=\"^/dist($|/)\" --ignore=\"^/\\.git($|/)\" --ignore=\"^/\\.appdata($|/)\" --ignore=\"^/tools/node($|/)\" --ignore=\"^/src($|/)\" --ignore=\"^/test($|/)\" --ignore=\"\\.ts$\" --ignore=\"\\.tsx$\" --ignore=\"\\.log$\"",
    "pack:smoke": "node build/tools/run-packaged-smoke.js"
  },
  "devDependencies": {
    "@electron/packager": "^19.1.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^41.1.1",
    "eslint": "^10.1.0",
    "jiti": "^2.6.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^8.0.10"
  },
  "dependencies": {
    "@tanstack/react-virtual": "^3.13.24",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  }
}
